{
  "_comment": "Sandbox build (src/main.ts -> dist/main.js via tsc). The UI is a single self-contained src/ui.html loaded raw by Pixso — no bundler.",
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["ES2017"],
    "strict": true,
    "moduleResolution": "node",
    "module": "CommonJS",
    "outDir": "./dist",
    "rootDir": "./src",
    "skipLibCheck": true,
    "typeRoots": ["./node_modules/@pixso/plugin-typings", "./node_modules/@types"]
  },
  "files": ["./node_modules/@pixso/plugin-typings/index.d.ts", "./src/main.ts"]
}
